---
const proofLinks = [
  { label: "Studi live", href: "https://studi-qypn.vercel.app/", note: "early access surface" },
  { label: "GitHub", href: "https://github.com/kausthubh-coder/studi", note: "source repo" },
  { label: "Interactive walkthrough", href: "/studi-demo/", note: "scroll demo mockup" },
  { label: "Project page", href: "/projects/studi/", note: "portfolio case study" },
];

const systemNodes = [
  { label: "Student", detail: "question, file, voice, or concept" },
  { label: "Studi chat", detail: "thread state, uploads, Sparks, billing UI" },
  { label: "Convex Agent", detail: "tutor behavior, tools, model routing" },
  { label: "Runtime layer", detail: "Scene, Code, Test, Voice" },
  { label: "Proof loop", detail: "tests, browser smoke, conclusion artifacts" },
];

const proofLedger = [
  {
    area: "Scene Spark v2",
    proof: "Merged to GitHub main and deployed to Vercel production as a sandboxed iframe runtime.",
    evidence: "Commit e31e4ea, deployment dpl_46teVhwgD81J3k5nLkZyKcoVLsQS READY, 5 files / 22 focused tests.",
    status: "Production code",
  },
  {
    area: "Code Spark provider",
    proof: "Provider-neutral Code/Test Spark surface with Convex Node action, Vercel Sandbox branch, visible checks, cleanup, and cooldown.",
    evidence: "Final integration marked merge-comfortable: 15 targeted UI/runtime tests and 9 focused Convex tests passed.",
    status: "Merge-ready source",
  },
  {
    area: "Realtime voice foundation",
    proof: "Reducer-based Realtime event model, Convex voice persistence, server-minted OpenAI Realtime sessions, and HTTP endpoint.",
    evidence: "31 unit tests and 11 Convex tests passed after final fixes.",
    status: "Foundation, not full live mode",
  },
  {
    area: "Engineering honesty",
    proof: "Provider/browser blockers and production auth constraints are documented instead of hidden.",
    evidence: "Signed-in deployed Scene smoke and live Vercel Sandbox production run are called out as separate verification gaps.",
    status: "Caveats explicit",
  },
];

const implemented = [
  {
    title: "Scene Spark v2 runtime",
    body:
      "A generated learning artifact can render as HTML/CSS/JS inside a sandboxed iframe, communicate through a small postMessage contract, and report ready, resize, interaction, checkpoint, and error events back to Studi.",
    bullets: [
      "Kept small visual scenes on iframe architecture instead of over-provisioning full VM sandboxes.",
      "Added runtime contract, validators, v2-first worker output requirements, compatibility with saved v1 artifacts, and browser-smoke proof path.",
      "Promoted the narrow Scene Spark lane without dragging Code Spark or Lab IDE work into the production merge.",
    ],
  },
  {
    title: "Code Spark / Test Spark provider boundary",
    body:
      "The code-learning surface is designed around editable starter files, visible checks, and an execution provider boundary that can use Vercel Sandbox without pretending every prototype already has full IDE semantics.",
    bullets: [
      "Convex action chooses the provider, enforces recent-run cooldown before sandbox creation, and cleans up short-lived sandboxes.",
      "Hidden tests are intentionally rejected in this v1 public session model so the UI does not imply secret grading that is not implemented.",
      "Local fake adapter remains test/dev support; production provider factory lives in the Convex runtime branch.",
    ],
  },
  {
    title: "Realtime voice foundation",
    body:
      "Voice work moved from transcript blobs toward a response/session model that can aggregate Realtime events before committing durable chat messages.",
    bullets: [
      "Reducer treats transcript deltas as draft state and response.done as the assistant commit boundary.",
      "Convex schema models sessions, utterances, responses, and raw Realtime events; server action mints OpenAI Realtime sessions.",
      "Remaining gap is honest: the live WebRTC client dispatcher and usage metering still need the next implementation pass.",
    ],
  },
];

const walkthroughChapters = [
  ["01", "Why Studi exists: tutor with tools, not a chat box."],
  ["02", "Architecture: chat to Convex Agent to Spark/voice runtimes."],
  ["03", "Spark generation: one tool surface, many backend workers."],
  ["04", "Scene Spark proof: runtime contract, iframe sandbox, deployed lane."],
  ["05", "Code Spark proof: provider boundary, visible checks, caveats."],
];
---

<main class="ai-proof-page">
  <a href="/" class="back-link">Back home</a>

  <section class="ai-proof-hero" aria-labelledby="ai-proof-title">
    <div class="ai-proof-hero__mark" aria-hidden="true">
      <img src="/logos/optimized/studi-paper-airplane-logo-rounded.webp" alt="" width="384" height="384" />
    </div>
    <div class="ai-proof-hero__copy">
      <p class="detail-kicker">AI engineer proof page</p>
      <h1 id="ai-proof-title">Studi: agentic tutor systems I actually implemented.</h1>
      <p>
        This is the employer-fast version of the work: what the AI system does, what I built around agents and runtimes,
        what is verified, and where I am intentionally not overclaiming yet.
      </p>
      <div class="ai-proof-links" aria-label="Primary proof links">
        {
          proofLinks.map((link) => (
            <a href={link.href}>
              <span>{link.label}</span>
              <small>{link.note}</small>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="ai-proof-section" aria-labelledby="architecture-title">
    <div class="ai-proof-section__heading">
      <p class="detail-kicker">system map</p>
      <h2 id="architecture-title">How the AI work is shaped.</h2>
    </div>
    <div class="system-diagram" aria-label="Studi AI architecture flow">
      {
        systemNodes.map((node, index) => (
          <div class="system-node">
            <span class="system-node__index">{String(index + 1).padStart(2, "0")}</span>
            <strong>{node.label}</strong>
            <small>{node.detail}</small>
          </div>
        ))
      }
    </div>
  </section>

  <section class="ai-proof-section" aria-labelledby="ledger-title">
    <div class="ai-proof-section__heading">
      <p class="detail-kicker">proof ledger</p>
      <h2 id="ledger-title">The fast scan for an interviewer.</h2>
    </div>
    <div class="proof-ledger">
      {
        proofLedger.map((item) => (
          <article class="proof-row">
            <div>
              <h3>{item.area}</h3>
              <p>{item.status}</p>
            </div>
            <p>{item.proof}</p>
            <p>{item.evidence}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section class="ai-proof-section" aria-labelledby="implemented-title">
    <div class="ai-proof-section__heading">
      <p class="detail-kicker">implemented systems</p>
      <h2 id="implemented-title">The AI engineering work underneath Studi.</h2>
    </div>
    <div class="implemented-list">
      {
        implemented.map((item) => (
          <article class="implemented-item">
            <h3>{item.title}</h3>
            <p>{item.body}</p>
            <ul>
              {item.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="ai-proof-video" aria-labelledby="video-title">
    <div class="ai-proof-video__poster" aria-hidden="true">
      <span class="scroll-glyph"></span>
      <p>scroll proof demo</p>
    </div>
    <div>
      <p class="detail-kicker">interactive walkthrough</p>
      <h2 id="video-title">Use the scroll demo instead of a passive video.</h2>
      <p>
        The Studi demo keeps a laptop pinned while the side panel explains features, architecture, code, and proof. It
        can use placeholder screens now, then real Studi clips or screenshots later.
      </p>
      <a class="proof-walkthrough-link" href="/studi-demo/">Open walkthrough</a>
      <ol class="video-chapters">
        {walkthroughChapters.map(([time, text]) => <li><span>{time}</span>{text}</li>)}
      </ol>
    </div>
  </section>

  <section class="ai-proof-section ai-proof-section--closing" aria-labelledby="interview-title">
    <div class="ai-proof-section__heading">
      <p class="detail-kicker">interview prompts</p>
      <h2 id="interview-title">Good questions to ask me.</h2>
    </div>
    <div class="question-list">
      <p>How would you decide when a generated learning artifact needs an iframe versus a real sandbox provider?</p>
      <p>How do you keep AI product claims honest when a provider integration is only partially verified?</p>
      <p>How would you move the Realtime voice reducer into the live WebRTC client path?</p>
    </div>
  </section>
</main>
