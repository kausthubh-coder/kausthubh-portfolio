<div class="intro-shell intro-shell--stack" aria-hidden="true">
  <div class="intro-flight">
    <div class="intro-piece-stage">
      <img
        class="intro-start-logo"
        src="/logo.webp"
        alt=""
        width="72"
        height="72"
        fetchpriority="high"
        decoding="async"
      />
    </div>
    <span class="intro-word-run">
      <span class="intro-name-tail">Kausthubh.</span>
      <span class="intro-word-n">N</span>
    </span>
  </div>
</div>

<script is:inline>
  (() => {
    const doc = document.documentElement;
    const shell = document.querySelector(".intro-shell");
    const flight = document.querySelector(".intro-flight");
    if (!shell || !flight || doc.dataset.introState === "done" || doc.dataset.introReady !== "true") return;

    const phases = ["stack", "word", "land"];
    const fallbackLogoSize = 72;
    const fallbackIdentityWidth = 360;
    const easeOut = "cubic-bezier(0.16, 1, 0.3, 1)";
    const timers = [];
    let activePhase = "stack";
    let viewportFrame = 0;

    const visualViewport = window.visualViewport;

    const removeViewportListeners = () => {
      window.removeEventListener("resize", keepCentered);
      visualViewport?.removeEventListener("resize", keepCentered);
      visualViewport?.removeEventListener("scroll", keepCentered);
      window.cancelAnimationFrame(viewportFrame);
    };

    const finish = () => {
      removeViewportListeners();
      shell.remove();
      doc.dataset.introState = "done";
      delete doc.dataset.introReady;
    };

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      finish();
      return;
    }

    const measure = () => {
      const target = document.querySelector(".identity-mark");
      const name = document.querySelector(".identity-name");
      const targetRect = target?.getBoundingClientRect();
      const nameRect = name?.getBoundingClientRect();
      const logoSize = Math.round(targetRect?.width || fallbackLogoSize);
      const identityWidth = Math.round(
        targetRect && nameRect ? nameRect.right - targetRect.left : fallbackIdentityWidth,
      );
      const viewportLeft = visualViewport?.offsetLeft || 0;
      const viewportTop = visualViewport?.offsetTop || 0;
      const viewportWidth = visualViewport?.width || window.innerWidth;
      const viewportHeight = visualViewport?.height || window.innerHeight;

      return {
        centerX: Math.round(viewportLeft + viewportWidth / 2),
        centerY: Math.round(viewportTop + viewportHeight / 2),
        logoSize,
        identityWidth,
        targetX: Math.round(targetRect?.left || viewportLeft + (viewportWidth - logoSize) / 2),
        targetY: Math.round(targetRect?.top || viewportTop + (viewportHeight - logoSize) / 2),
      };
    };

    const scaleFor = (phase) => {
      if (phase === "stack") return 1.56;
      if (phase === "word") return 1.04;
      return 1;
    };

    const place = (phase, immediate = false) => {
      activePhase = phase;
      const metrics = measure();
      const scale = scaleFor(phase);
      const visualWidth = phase === "word" ? metrics.identityWidth : metrics.logoSize;
      const x = phase === "land" ? metrics.targetX : Math.round(metrics.centerX - (visualWidth * scale) / 2);
      const y = phase === "land" ? metrics.targetY : Math.round(metrics.centerY - (metrics.logoSize * scale) / 2);

      phases.forEach((name) => shell.classList.toggle(`intro-shell--${name}`, name === phase));
      flight.style.transitionDuration = immediate ? "0ms" : phase === "land" ? "480ms" : "280ms";
      flight.style.transitionTimingFunction = easeOut;
      flight.style.transform = `translate3d(${x}px, ${y}px, 0) scale(${scale})`;
    };

    function keepCentered() {
      window.cancelAnimationFrame(viewportFrame);
      viewportFrame = window.requestAnimationFrame(() => place(activePhase, true));
    }

    place("stack", true);
    shell.dataset.ready = "true";

    window.addEventListener("resize", keepCentered, { passive: true });
    visualViewport?.addEventListener("resize", keepCentered, { passive: true });
    visualViewport?.addEventListener("scroll", keepCentered, { passive: true });

    timers.push(window.setTimeout(() => place("word"), 900));
    timers.push(window.setTimeout(() => place("land"), 1420));
    timers.push(window.setTimeout(finish, 1840));
  })();
</script>
