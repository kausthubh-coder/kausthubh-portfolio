---
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  introBoot?: boolean;
};

const {
  title = "kausthubh",
  description = "A first portfolio surface for Kausthubh N.",
  introBoot = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="oklch(1 0 0)" />
    <link rel="icon" href="/favicon.png" type="image/png" sizes="64x64" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="preload" href="/logo.webp" as="image" type="image/webp" fetchpriority="high" />
    <link rel="preload" href="/fonts/sora-latin-variable.woff2" as="font" type="font/woff2" crossorigin />
    {
      introBoot && (
        <script is:inline>
          (() => {
            const storageKey = "kausthubh:intro:v5";
            const doc = document.documentElement;
            const isReload = () => {
              const nav = performance.getEntriesByType("navigation")[0];
              return nav && nav.type === "reload";
            };
            const readPlayed = () => {
              try {
                return window.sessionStorage.getItem(storageKey) === "1";
              } catch {
                return false;
              }
            };
            const writePlayed = () => {
              try {
                window.sessionStorage.setItem(storageKey, "1");
              } catch {
                return;
              }
            };

            if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
              doc.dataset.introState = "done";
              return;
            }

            if (readPlayed() && !isReload()) {
              doc.dataset.introState = "done";
              return;
            }

            writePlayed();
            window.__kausthubhIntroStarted = true;
            doc.dataset.introState = "running";
            doc.dataset.introReady = "true";
          })();
        </script>
      )
    }
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
